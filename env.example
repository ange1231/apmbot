# Прокси для подключения к Telegram (нужен если Telegram заблокирован в твоём регионе)
# Формат: http://логин:пароль@айпи:порт
PROXY_URL=http://540311:573050@185.76.241.171:43916

# Внутренний API бота — сайт обращается к боту по этому порту для проверки подписок
# Порт должен быть свободен и не торчать в интернет (только 127.0.0.1)
BOT_API_PORT=8765
# Секрет — любая длинная случайная строка, одинаковая в боте и на сайте
BOT_API_SECRET=замени-на-случайную-строку-минимум-32-символа

